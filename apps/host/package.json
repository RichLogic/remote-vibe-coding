{
  "name": "@rvc/host",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "MONGODB_URL=\"${MONGODB_URL:-mongodb://127.0.0.1:27017/?directConnection=true}\" tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "MONGODB_URL=\"${MONGODB_URL:-mongodb://127.0.0.1:27017/?directConnection=true}\" node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/app/*.test.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.3.0",
    "fastify": "^5.8.2",
    "mongodb": "^6.17.0",
    "pdf-parse": "^2.4.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
